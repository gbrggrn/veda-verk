@inherits LayoutComponentBase

<div class="page d-flex flex-column min-vh-100 homep-bg">
    <!-- Header -->
    <div class="d-flex align-items-start justify-content-center text-center">
        <div class="content-overlay mt-5 mb-4">
            <h1 class="display-2 fw-bold title-text">Veda Verk</h1>
            <p class="lead fw-normal sub-title-text">Småskalig trädgårdsodling och mathantverk</p>
        </div>
    </div>

    <!-- Body -->
    <div class="main flex-grow-1">
        @Body
    </div>

    <!-- Footer -->
    <div class="site-footer text-center mt-5 pb-4">
        <div class="container">

            <!-- Social Links -->
            <div class="social-links mb-3">

                <!-- Github -->
                <a href="https://github.com/gbrggrn/csharp-blazor-veda-verk" target="_blank" class="social-icon mx-2" style="color: #214E34;">
                    <i class="bi bi-github display-6 fs-2"></i>
                </a>

                <!-- Instagram -->
                <a href="http://instagram.com/veda.verk" class="social-icon mx-2" style="color: #214E34;">
                    <i class="bi bi-instagram display-6 fs-2"></i>
                </a>

                <!-- Mailto -->
                <a href="mailto:your.email@example.com" class="social-icon mx-2" style="color: #214E34;">
                    <i class="bi bi-envelope-fill display-6 fs-2"></i>
                </a>
            </div>

            <!-- Footer nav -->
            <div class="footer-nav mb-3 d-flex justify-content-center gap-3 flex-wrap">
                <NavLink href="/Home/Home" class="footer-text text-decoration-none">Home</NavLink>
                <NavLink href="/About/About" class="footer-text text-decoration-none">About</NavLink>
                <NavLink href="/About/Contact" class="footer-text text-decoration-none">Contact</NavLink>
                <NavLink href="/About/Privacy" class="footer-text text-decoration-none">Privacy</NavLink>

                <AuthorizeView>
                    <Authorized>
                        <NavLink href="Admin/Dashboard" class="footer-text text-decoration-none">Dashboard</NavLink>
                        <form action="Account/Logout" method="post" class="d-inline">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="" />
                            <button type="submit" class="footer-text text-decoration-none bg-transparent border-0 p-0">
                                Logout
                            </button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="Account/Login" class="footer-text text-decoration-none" target="_top">Login</a>
                    </NotAuthorized>
                </AuthorizeView>

            </div>

            <!-- Date -->
            <div class="footer-text small">
                &copy; @DateTime.Now.Year Veda Verk
            </div>
        </div>

    </div>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

